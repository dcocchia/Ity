{
  "name": "ity",
  "version": "2.0.0",
  "description": "A tiny dependency-free reactive app kernel with MVC compatibility",
  "main": "dist/ity.cjs.js",
  "module": "dist/ity.esm.mjs",
  "browser": "dist/ity.js",
  "types": "dist/ity.d.ts",
  "unpkg": "dist/ity.min.js",
  "jsdelivr": "dist/ity.min.js",
  "exports": {
    "import": "./dist/ity.esm.mjs",
    "require": "./dist/ity.cjs.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest",
    "pretest": "tsc -p tsconfig.json && cp build/Ity.js Ity.js",
    "precoverage": "tsc -p tsconfig.json && cp build/Ity.js Ity.js",
    "coverage": "jest --coverage",
    "build": "tsc -p tsconfig.json && rollup -c",
    "test:dist": "ITY_FILE=../../dist/ity.min.js npm test -- --coverage=false"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/node": "^20",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.17.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dcocchia/Ity.git"
  },
  "keywords": [
    "ity",
    "reactivity",
    "signals",
    "web-components",
    "mvc",
    "spa"
  ],
  "author": "Dominic Cocchiarella",
  "license": "MIT"
}
